{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Status Monitor Design",
  "scopeName": "source.smd",
  "patterns": [
    { "include": "#comment" },
    { "include": "#start-marker" },
    { "include": "#preprocessor" },
    { "include": "#config-line" },
    { "include": "#command" },
    { "include": "#expression" }
  ],
  "repository": {

    "comment": {
      "name": "comment.line.semicolon.smd",
      "begin": ";",
      "end": "$",
      "patterns": []
    },

    "start-marker": {
      "match": "^\\s*(Start)\\s*(:)\\s*$",
      "captures": {
        "1": { "name": "keyword.control.start.smd" },
        "2": { "name": "punctuation.separator.smd" }
      }
    },

    "preprocessor": {
      "patterns": [
        {
          "match": "^\\s*(#endif|#else|#endfor)\\b",
          "captures": {
            "1": { "name": "keyword.control.conditional.smd" }
          }
        },
        {
          "begin": "^\\s*(#if|#elif)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.conditional.smd" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comment" },
            { "include": "#expression" }
          ]
        },
        {
          "begin": "^\\s*(#for)\\b",
          "beginCaptures": {
            "1": { "name": "keyword.control.loop.smd" }
          },
          "end": "$",
          "patterns": [
            { "match": "\\bin\\b", "name": "keyword.control.loop.smd" },
            { "include": "#comment" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "config-line": {
      "patterns": [
        {
          "comment": "`Name = ...` -- always colour the right-hand side as a string, whether the author quoted it or not. The parser accepts both `Name = Foo` and `Name = \"Foo\"`; treating both as strings avoids the surprise of bare words splitting into separate identifier tokens.",
          "begin": "^\\s*(Name)\\s*(=)(?!=)\\s*",
          "beginCaptures": {
            "1": { "name": "variable.other.constant.smd" },
            "2": { "name": "keyword.operator.assignment.constant.smd" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comment" },
            {
              "comment": "Quoted form -- highlight escapes properly.",
              "include": "#string-literal"
            },
            {
              "comment": "Bare form -- colour the rest of the line up to a comment (or EOL) as an unquoted string. Stops at `;` so trailing comments still highlight.",
              "match": "[^;\\n]+",
              "name": "string.unquoted.name.smd"
            }
          ]
        },
        {
          "comment": "Constant-kind (=): immutable, VAR cannot rebind. Highlighted distinctly from `:`.",
          "begin": "^\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(=)(?!=)",
          "beginCaptures": {
            "1": { "name": "variable.other.constant.smd" },
            "2": { "name": "keyword.operator.assignment.constant.smd" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comment" },
            { "include": "#config-value" }
          ]
        },
        {
          "comment": "Default-kind (:) -- only matched outside a render block. Must precede the colon with an identifier and not be a `Start:` marker.",
          "begin": "^\\s*(?!Start\\s*:)([A-Za-z_][A-Za-z0-9_]*)\\s*(:)",
          "beginCaptures": {
            "1": { "name": "variable.other.smd" },
            "2": { "name": "keyword.operator.assignment.default.smd" }
          },
          "end": "$",
          "patterns": [
            { "include": "#comment" },
            { "include": "#config-value" }
          ]
        }
      ]
    },

    "config-value": {
      "patterns": [
        { "include": "#history-decl" },
        { "include": "#graph-conditions-decl" },
        { "include": "#list-decl" },
        { "include": "#ietf-decl" },
        { "include": "#color-pseudo" },
        { "include": "#format-spec" },
        { "include": "#expression" }
      ]
    },

    "history-decl": {
      "begin": "\\b(HISTORY)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.type.history.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        {
          "match": "\\b(int|float|double)\\b",
          "name": "storage.type.history.smd"
        },
        { "include": "#expression" }
      ]
    },

    "list-decl": {
      "begin": "\\b(LIST)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.type.list.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        {
          "match": "\\b(int|float|double|str)\\b",
          "name": "storage.type.list.smd"
        },
        {
          "begin": "\\b(RANGE)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "support.function.range.smd" },
            "2": { "name": "punctuation.section.braces.begin.smd" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.section.braces.end.smd" }
          },
          "patterns": [
            { "include": "#expression" }
          ]
        },
        { "include": "#string-literal" },
        { "include": "#expression" }
      ]
    },

    "graph-conditions-decl": {
      "begin": "\\b(GRAPH_CONDITIONS)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.type.graph-conditions.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "ietf-decl": {
      "comment": "IETF{\"default string\"} -- config-value form. RHS of a `key = IETF{...}` line. The string inside is the fallback text when no matching locale is active.",
      "begin": "\\b(IETF)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.type.ietf.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        { "include": "#string-literal" },
        { "include": "#expression" }
      ]
    },

    "color-pseudo": {
      "begin": "\\b(COLOR)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.function.color.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "history-average": {
      "comment": "HISTORY_AVERAGE{name} -- numeric expression that evaluates to the arithmetic mean of the named ring buffer. Usable anywhere a number can appear.",
      "begin": "\\b(HISTORY_AVERAGE)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.function.history-average.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "ietf-get": {
      "comment": "IETF_GET{name} -- expression form that resolves to the locale-specific string bound to `name`. Used as TEXT / GET_DIMENSIONS trailing arg, or anywhere a string expression is expected.",
      "begin": "\\b(IETF_GET)\\s*(\\{)",
      "beginCaptures": {
        "1": { "name": "support.function.ietf-get.smd" },
        "2": { "name": "punctuation.section.braces.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.braces.end.smd" }
      },
      "patterns": [
        { "include": "#expression" }
      ]
    },

    "format-spec": {
      "comment": "{ \"printf-fmt\", arg, arg, ... } -- re-evaluated each frame.",
      "begin": "(\\{)\\s*(?=\")",
      "beginCaptures": {
        "1": { "name": "punctuation.section.format.begin.smd" }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": { "name": "punctuation.section.format.end.smd" }
      },
      "patterns": [
        { "include": "#format-string" },
        { "include": "#expression" }
      ]
    },

    "format-string": {
      "name": "string.quoted.double.format.smd",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "comment": "printf conversions. Length modifiers (h, hh, l, ll) are accepted but ignored by the parser; we still highlight them for visual consistency.",
          "match": "%[-+#0 ]*[0-9]*(\\.[0-9]+)?(hh|h|ll|l|j|z|t|L)?[diouxXfFeEgGaAcsS%]",
          "name": "constant.other.placeholder.smd"
        },
        { "include": "#string-escape" }
      ]
    },

    "command": {
      "patterns": [
        {
          "comment": "IETF_LOCALE and NAME_LOCALE: standalone directive lines in the config section (no key/separator). They take name + locale-code + string args.",
          "begin": "^\\s*(IETF_LOCALE|NAME_LOCALE)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "support.function.ietf.smd" },
            "2": { "name": "punctuation.section.braces.begin.smd" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.section.braces.end.smd" }
          },
          "patterns": [
            { "include": "#string-literal" },
            { "include": "#expression" }
          ]
        },
        {
          "comment": "Render commands: name followed by an opening brace.",
          "begin": "\\b(TEXT|BOX|ROUNDED_BOX|EMPTY_BOX|DASHED_LINE|GET_DIMENSIONS|VAR|HISTORY_UPDATE|HISTORY_CLEAN|GRAPH_LINE_CHART)\\s*(\\{)",
          "beginCaptures": {
            "1": { "name": "support.function.command.smd" },
            "2": { "name": "punctuation.section.braces.begin.smd" }
          },
          "end": "(\\})",
          "endCaptures": {
            "1": { "name": "punctuation.section.braces.end.smd" }
          },
          "patterns": [
            {
              "match": "\\b(LEFT_TO_RIGHT|RIGHT_TO_LEFT)\\b",
              "name": "constant.language.direction.smd"
            },
            { "include": "#history-average" },
            { "include": "#ietf-get" },
            { "include": "#color-pseudo" },
            { "include": "#format-spec" },
            { "include": "#expression" }
          ]
        }
      ]
    },

    "expression": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#history-average" },
        { "include": "#ietf-get" },
        { "include": "#color-pseudo" },
        { "include": "#format-spec" },
        { "include": "#string-literal" },
        { "include": "#number" },
        { "include": "#boolean" },
        { "include": "#predefined-host" },
        { "include": "#system-key" },
        { "include": "#builtin-function" },
        { "include": "#config-default-name" },
        { "include": "#operator" },
        { "include": "#punctuation" },
        { "include": "#identifier" }
      ]
    },

    "string-literal": {
      "name": "string.quoted.double.smd",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "include": "#string-escape" }
      ]
    },

    "string-escape": {
      "match": "\\\\.",
      "name": "constant.character.escape.smd"
    },

    "number": {
      "patterns": [
        {
          "comment": "Hex literals.",
          "match": "\\b0[xX][0-9A-Fa-f]+\\b",
          "name": "constant.numeric.hex.smd"
        },
        {
          "comment": "Decimal float/int. Leading sign handled by #operator.",
          "match": "\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b",
          "name": "constant.numeric.decimal.smd"
        }
      ]
    },

    "boolean": {
      "match": "\\b(true|false)\\b",
      "name": "constant.language.boolean.smd"
    },

    "predefined-host": {
      "comment": "Host-bound names the parser exposes by convention. Listed verbatim rather than by prefix so a typo like `Game_Fps_int` doesn't accidentally get the predefined color.",
      "match": "\\b(CPU_Hz_int|CPU_RealHz_int|CPU_DeltaHz_int|CPU_Core0Load_double|CPU_Core1Load_double|CPU_Core2Load_double|CPU_Core3Load_double|GPU_Hz_int|GPU_RealHz_int|GPU_DeltaHz_int|GPU_Load_int|RAM_Hz_int|RAM_RealHz_int|RAM_DeltaHz_int|RAM_LoadAll_int|RAM_LoadCPU_int|RAM_UsedAllMB_float|RAM_TotalAllMB_float|RAM_UsedApplicationMB_float|RAM_TotalApplicationMB_float|RAM_UsedAppletMB_float|RAM_TotalAppletMB_float|RAM_UsedSystemMB_float|RAM_TotalSystemMB_float|RAM_UsedSystemUnsafeMB_float|RAM_TotalSystemUnsafeMB_float|RAM_HocClkRamBWAll_int|RAM_HocClkRamBWCpu_int|RAM_HocClkRamBWGpu_int|RAM_HocClkRamBWPeak_int|Board_ChargerCurrentLimit_int|Board_ChargerVoltageLimit_int|Board_ChargerConnected_int|Board_BatteryCurrentAvg_float|Board_BatteryVoltageAvg_float|Board_IsBatteryFiltered|Board_BatteryAgePercentage_float|Board_BatteryChargePercentage_float|Board_BatteryTemperatureCelcius_float|Board_DesignedFullBatteryCapacity_float|Board_ActualFullBatteryCapacity_float|Board_PowerConsumption_float|Board_BatteryTimeEstimateInMinutes_int|Board_SocTemperatureCelsius_float|Board_PcbTemperatureCelsius_float|Board_SkinTemperatureMiliCelsius_int|Board_FanRotationPercentageLevel_float|Board_HocClkThermalSensorCPU_int|Board_HocClkThermalSensorGPU_int|Board_HocClkThermalSensorMEM_int|Board_HocClkThermalSensorPLLX_int|Board_HocClkThermalSensorAO_int|Board_HocClkThermalSensorBQ24193_int|Game_LastFrameNumber_int|Game_IsGameRunning|Game_FPS_int|Game_FpsAvgOld_float|Game_FpsAvg_float|Game_ReadSpeedPerSecond_float|Game_ResolutionRenderCalls_int|Game_ResolutionViewportCalls_int|System_DisplayRefreshRate_int|System_IsDocked|System_KeysDown_int|System_KeysHeld_int|formattedKeyCombo|Misc_IsWiFiPassphrase|Misc_NvDecHz_int|Misc_NvEncHz_int|Misc_NvJpgHz_int|Misc_NetworkConnectionType_int|Misc_WiFiPassphrase_str)\\b",
      "name": "support.variable.predefined.host.smd"
    },

    "system-key": {
      "comment": "System_Key_* button constants -- preprocessed into integer literals at compile time.",
      "match": "\\b(System_Key_A|System_Key_B|System_Key_X|System_Key_Y|System_Key_StickL|System_Key_StickR|System_Key_L|System_Key_R|System_Key_ZL|System_Key_ZR|System_Key_Plus|System_Key_Minus|System_Key_Left|System_Key_Up|System_Key_Right|System_Key_Down|System_Key_LeftSL|System_Key_LeftSR|System_Key_RightSL|System_Key_RightSR)\\b",
      "name": "constant.language.system-key.smd"
    },

    "builtin-function": {
      "match": "\\b(round|trunc|floor|ceil|abs|sqrt|min|max|color|log|exp|sin|cos|tan|asin|acos|atan|atan2|sinh|cosh|tanh|log10|pow|fmod)\\s*(?=\\()",
      "name": "support.function.builtin.smd"
    },

    "config-default-name": {
      "comment": "Writable defaults seeded by the parser. Highlighted to give them a slightly different shade from user-defined identifiers -- catches typos in commonly-overridden keys.",
      "match": "\\b(COMMON_MARGIN|BackgroundColor|ComboButtonFooter|Movable|User_RefreshRate|EnableGame|EnableCPU|EnableGPU|EnableRAM|EnableBoard|EnableMisc|LayerWidth|LayerHeight|LayerPos_x|LayerPos_y|HeaderText|FooterText|UseCustomExitCombo|EnableControls|Name)\\b",
      "name": "variable.other.config-default.smd"
    },

    "operator": {
      "patterns": [
        {
          "comment": "Comparators and logical keywords.",
          "match": "(==|!=|<=|>=|<|>)|\\b(and|or)\\b",
          "name": "keyword.operator.comparison.smd"
        },
        {
          "comment": "Arithmetic and string-concat.",
          "match": "\\+|-|\\*\\*|\\*|/|%|\\^",
          "name": "keyword.operator.arithmetic.smd"
        },
        {
          "comment": "Ternary.",
          "match": "\\?|:",
          "name": "keyword.operator.ternary.smd"
        },
        {
          "comment": "Variable-marker $ prefix.",
          "match": "\\$",
          "name": "keyword.operator.variable-marker.smd"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        { "match": "\\{",  "name": "punctuation.section.braces.begin.smd" },
        { "match": "\\}",  "name": "punctuation.section.braces.end.smd" },
        { "match": "\\[",  "name": "punctuation.section.brackets.begin.smd" },
        { "match": "\\]",  "name": "punctuation.section.brackets.end.smd" },
        { "match": "\\(",  "name": "punctuation.section.parens.begin.smd" },
        { "match": "\\)",  "name": "punctuation.section.parens.end.smd" },
        { "match": ",",    "name": "punctuation.separator.smd" },
        { "match": "\\.",  "name": "punctuation.accessor.smd" }
      ]
    },

    "identifier": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.smd"
    }
  }
}