service: sys:clk

structs:
	- SysClkContext:
		- 0x20, u32, "CPU_RealHz_int"
		- 0x24, u32, "GPU_RealHz_int"
		- 0x28, u32, "RAM_RealHz_int"
		- 0x4C, u32, "RAM_LoadAll_int"
		- 0x50, u32, "RAM_LoadCPU_int"
		
cmds:
	- "GetApiVersion", 0, u32
	- "GetVersionString", 1, buffer, 0x100, char
	- "GetCurrentContext", 2, buffer, 0x78, struct SysClkContext
  
asserts:
	GetApiVersion() >= 4
	GetVersionString() == "2.0.(.*)"
	
execution:
	GetCurrentContext()